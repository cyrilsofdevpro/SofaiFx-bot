# ============================================
# Data API Keys - Market Data
# ============================================
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here
ALPHA_VANTAGE_KEY=your_alpha_vantage_api_key_here
NEWS_API_KEY=your_news_api_key_here

# ============================================
# AI/ML Integration - Hugging Face
# ============================================
HF_API_KEY=your_huggingface_api_key_here

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=sqlite:///sofai_fx.db
# Alternative: postgresql://user:password@localhost:5432/sofai_fx

# ============================================
# Trading Platform Integration
# ============================================
MT5_API_URL=http://localhost:5005
MT5_LOGIN=your_mt5_login
MT5_PASSWORD=your_mt5_password
MT5_SERVER=your_mt5_server

# ============================================
# Telegram Notifications (Optional)
# ============================================
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ============================================
# Email Settings (Optional)
# ============================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_password

# ============================================
# Trading Settings
# ============================================
UPDATE_INTERVAL=3600
CURRENCY_PAIRS=EURUSD,GBPUSD,USDJPY,GBPJPY,EURJPY,AUDJPY,USDCAD
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30
BACKTEST_START_DATE=2023-01-01
BACKTEST_END_DATE=2024-12-31

# ============================================
# Flask Application Configuration
# ============================================
FLASK_ENV=development
FLASK_DEBUG=False
FLASK_PORT=5000
SECRET_KEY=your_secret_key_for_flask_sessions

# ============================================
# Backtesting & Optimization
# ============================================
BACKTEST_INITIAL_BALANCE=10000
BACKTEST_COMMISSION=0.001
BACKTEST_SLIPPAGE=0.0002
OPTIMIZATION_ENABLED=True
OPTIMIZATION_FREQUENCY=50  # Optimize every 50 trades

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FILE=logs/sofai_fx.log
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5

# ============================================
# Signal Configuration (Weights)
# ============================================
SIGNAL_SENTIMENT_WEIGHT=0.50
SIGNAL_TECHNICAL_WEIGHT=0.25
SIGNAL_PATTERN_WEIGHT=0.15
SIGNAL_NEWS_WEIGHT=0.10
SIGNAL_MIN_CONFIDENCE=0.55

# ============================================
# Cache Settings
# ============================================
CACHE_TTL_SENTIMENT=300  # 5 minutes in seconds
CACHE_TTL_BACKTEST=600   # 10 minutes in seconds

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_REQUESTS_PER_SEC=1
RATE_LIMIT_BATCH_SIZE=10

# ============================================
# Execution Settings
# ============================================
EXECUTION_RETRY_ATTEMPTS=3
EXECUTION_RETRY_DELAY=2  # seconds
SLIPPAGE_TOLERANCE=0.002  # 0.2%
DEMO_MODE=True  # Set to False for real trading
